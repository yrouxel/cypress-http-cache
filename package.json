{
  "name": "cypress-http-cache",
  "version": "1.1.0",
  "description": "In-memory http cache for Cypress.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts src/server.ts --format cjs --dts --watch",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:server": "node test/test-server.js",
    "cy:run": "cypress run --headless"
  },
  "keywords": [
    "cypress",
    "http",
    "cache"
  ],
  "author": "Yoann Rouxel <yoann.rouxelduval@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/http-proxy": "^1.17.14",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "cypress": "^15.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "lru-cache": "^11.2.7"
  }
}
